{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Proyecto",
  "version": "1.0.19",
  "identifier": "com.crozzo.pos",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Proyecto",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwRUU5RDE1MkU1QTNDOUUKUldTZVBGb3VGWjN1b0UrTXVKSzVpK0tBUjNVNC9uNUM2a093YkdhVmswQnVyTElmSjkrZXRJT2cK",
      "endpoints": [
        "https://github.com/kenny14ramirez-prog/Principal/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
