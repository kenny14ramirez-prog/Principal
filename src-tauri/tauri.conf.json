{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Crozzo POS",
  "version": "1.0.0",
  "identifier": "com.crozzo.pos",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run serve"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Crozzo POS",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "",
      "endpoints": [
        "https://github.com/kenny14ramirez-prog/Principal/releases/latest/download/latest.json"
      ]
    }
  }
}
